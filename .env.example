# Copy this file to .env and fill in the values before running docker compose.
# Never commit your .env file to source control.

# PostgreSQL credentials — MUST be changed before production deployment
POSTGRES_DB=psono
POSTGRES_USER=psono
POSTGRES_PASSWORD=change-me-use-a-strong-random-password

# Django secret key — MUST be set to a long, random, unique string.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-use-a-long-random-secret-key
